// Buckets collections/refunds into labeled periods (day/week/month/year) for the chart.
function periodKey(dateStr, gran){
  const d = new Date(dateStr);
  if(gran === 'day') return d.toISOString().slice(0,10);
  if(gran === 'year') return String(d.getFullYear());
  if(gran === 'month') return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0');
  // week: Monday-start ISO-ish week key
  const monday = new Date(d);
  const day = (d.getDay() + 6) % 7;
  monday.setDate(d.getDate() - day);
  return monday.toISOString().slice(0,10);
}
function renderFinanceChart(){
  const gran = financeGranularity;
  const buckets = {};
  allCollections.forEach(function(c){
    const k = periodKey(c.collected_date, gran);
    buckets[k] = buckets[k] || { collected:0, refunded:0 };
    buckets[k].collected += Number(c.amount_paid||0);
  });
  allRefunds.forEach(function(r){
    const k = periodKey(r.refund_date, gran);
    buckets[k] = buckets[k] || { collected:0, refunded:0 };
    buckets[k].refunded += Number(r.amount||0);
  });
  const keys = Object.keys(buckets).sort();
  const collectedData = keys.map(function(k){ return buckets[k].collected; });
  const refundedData = keys.map(function(k){ return buckets[k].refunded; });
  const profitData = keys.map(function(k){ return buckets[k].collected - buckets[k].refunded; });

  const ctx = document.getElementById('financeChart').getContext('2d');
  if(financeChartInstance) financeChartInstance.destroy();
  if(typeof Chart === 'undefined') return;
  financeChartInstance = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: keys,
      datasets: [
        { label: 'Collected', data: collectedData, backgroundColor: '#2F6F62' },
        { label: 'Refunded', data: refundedData, backgroundColor: '#C2643E' },
        { label: 'Profit', data: profitData, type: 'line', borderColor: '#CB8A2E', backgroundColor: '#CB8A2E', tension: 0.25 }
      ]
    },
    options: { responsive: true, scales: { y: { beginAtZero: true } } }
  });
}

['fChartDay','fChartWeek','fChartMonth','fChartYear'].forEach(function(id){
