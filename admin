function wireBanBox(r){
  const role = currentAdmin ? currentAdmin.role : null;
  if(!canBanTutor(role)) return;
  const msgEl = document.getElementById('banSaveMsg');

  const fullBtn = document.getElementById('banFullBtn');
  if(fullBtn) fullBtn.addEventListener('click', () => {
    document.getElementById('banFullForm').style.display = 'flex';
  });
  const fullConfirm = document.getElementById('banFullConfirm');
  if(fullConfirm) fullConfirm.addEventListener('click', async () => {
    const reason = document.getElementById('banFullReason').value.trim();
    if(!reason){ msgEl.textContent = 'Please give a reason.'; return; }
    fullConfirm.disabled = true;
    msgEl.textContent = 'Saving...';
    try{
      const { error } = await sb.rpc('officer_ban_tutor_full', {
        p_admin_username: currentAdmin.username, p_admin_password_hash: currentAdmin.password_hash,
        p_tutor_whatsapp: r.whatsapp, p_reason: reason
      });
      if(error) throw error;
      r.is_banned = true; r.ban_reason = reason; r.banned_by = currentAdmin.username; r.banned_at = new Date().toISOString();
      msgEl.textContent = 'Tutor fully banned.';
      applyFilters();
      refreshDrawerBanBox(r);
    }catch(err){ console.error(err); msgEl.textContent = 'Failed. ' + (err.message||''); fullConfirm.disabled = false; }
  });

  const unbanFullBtn = document.getElementById('banUnbanFullBtn');
  if(unbanFullBtn) unbanFullBtn.addEventListener('click', async () => {
    if(!confirm('Remove the full ban on this tutor?')) return;
    unbanFullBtn.disabled = true;
    msgEl.textContent = 'Saving...';
    try{
      const { error } = await sb.rpc('officer_unban_tutor_full', {
        p_admin_username: currentAdmin.username, p_admin_password_hash: currentAdmin.password_hash,
        p_tutor_whatsapp: r.whatsapp
      });
      if(error) throw error;
      r.is_banned = false; r.ban_reason = null; r.banned_by = null; r.banned_at = null;
      msgEl.textContent = 'Ban removed.';
      applyFilters();
      refreshDrawerBanBox(r);
    }catch(err){ console.error(err); msgEl.textContent = 'Failed. ' + (err.message||''); unbanFullBtn.disabled = false; }
  });

  const soaBtn = document.getElementById('banSoaBtn');
  if(soaBtn) soaBtn.addEventListener('click', () => {
    document.getElementById('banSoaForm').style.display = 'flex';
  });
  const soaConfirm = document.getElementById('banSoaConfirm');
  if(soaConfirm) soaConfirm.addEventListener('click', async () => {
    const days = Number(document.getElementById('banSoaDays').value);
    const reason = document.getElementById('banSoaReason').value.trim();
    if(!days || days < 1){ msgEl.textContent = 'Enter a valid number of days.'; return; }
    soaConfirm.disabled = true;
    msgEl.textContent = 'Saving...';
    try{
      const { data, error } = await sb.rpc('officer_soa_temp_ban_tutor', {
        p_admin_username: currentAdmin.username, p_admin_password_hash: currentAdmin.password_hash,
        p_tutor_whatsapp: r.whatsapp, p_days: days, p_reason: reason || null
      });
      if(error) throw error;
      r.soa_ban_until = data; r.soa_ban_reason = reason || null; r.soa_ban_by = currentAdmin.username;
      msgEl.textContent = 'Tutor temporarily removed from Son of Anton for ' + days + ' day(s).';
      applyFilters();
      refreshDrawerBanBox(r);
    }catch(err){ console.error(err); msgEl.textContent = 'Failed. ' + (err.message||''); soaConfirm.disabled = false; }
  });

  const soaEndBtn = document.getElementById('banSoaEndBtn');
  if(soaEndBtn) soaEndBtn.addEventListener('click', async () => {
    if(!confirm('End this tutor\'s Son of Anton ban early?')) return;
    soaEndBtn.disabled = true;
    msgEl.textContent = 'Saving...';
    try{
      const { error } = await sb.rpc('officer_soa_unban_tutor', {
        p_admin_username: currentAdmin.username, p_admin_password_hash: currentAdmin.password_hash,
        p_tutor_whatsapp: r.whatsapp
      });
      if(error) throw error;
      r.soa_ban_until = null; r.soa_ban_reason = null; r.soa_ban_by = null;
      msgEl.textContent = 'SoA ban ended.';
      applyFilters();
      refreshDrawerBanBox(r);
    }catch(err){ console.error(err); msgEl.textContent = 'Failed. ' + (err.message||''); soaEndBtn.disabled = false; }
  });
}

