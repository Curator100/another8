/* =====================================================================
   SON OF ANTON — tutor matching engine
   ===================================================================== */

// Reuses the same column set as the Applicants tab so computeRating() scores
// tutors identically here as it does there.
const APPLICANT_MATCH_COLUMNS = SELECT_COLUMNS;

// Holds whichever tutor list is currently rendered in the match modal, so the
// "Show Details" buttons can look the full row back up by index.
let lastMatchPool = [];
// The tutor already given this tuition's number (pinned card at the top of the
// modal) — kept separately so its own "Show Details" button works even though
// it's excluded from the ranked pool below it.
let pinnedMatchTutor = null;

// Turns a tuition's freeform "class" text (e.g. "Class 9-10", "SSC", "Class 4")
// into the set of preferred_class_levels buckets that would satisfy it.
// Returns null if the text can't be parsed at all (in which case the class
// requirement is skipped rather than blocking every tutor on a guess).
function classToBuckets(text){
  if(!text) return null;
  const t = text.toLowerCase();
  const buckets = new Set();
  // Free-text "SSC"/"HSC" keywords still map onto the underlying class numbers.
  if(t.includes('ssc')){ buckets.add('class_9'); buckets.add('class_10'); }
  if(t.includes('hsc')){ buckets.add('class_11'); buckets.add('class_12'); }
  const nums = t.match(/\d+/g) || [];
  nums.forEach(function(nStr){
    const n = Number(nStr);
    if(n >= 1 && n <= 5) buckets.add('class_1_5');
    else if(n >= 6 && n <= 8) buckets.add('class_6_8');
    else if(n === 9) buckets.add('class_9');
    else if(n === 10) buckets.add('class_10');
    else if(n === 11) buckets.add('class_11');
    else if(n === 12) buckets.add('class_12');
  });
  return buckets.size ? buckets : null;
}

// Builds the list of mandatory requirements for a tuition. Each requirement
// only applies if the tuition actually specifies a non-"any" value.
function buildMatchRequirements(t){
  const reqs = [];

  if(t.gender && t.gender !== 'any'){
    reqs.push({
      key:'gender', label:'Gender: ' + (TUITION_LABELS.gender[t.gender]||t.gender),
      test: function(r){ return r.gender === t.gender; }
    });
  }
  if(t.religion && t.religion !== 'any'){
    reqs.push({
      key:'religion', label:'Religion: ' + (TUITION_LABELS.religion[t.religion]||t.religion),
      test: function(r){ return r.religion === t.religion; }
    });
  }
  if(t.university && t.university !== 'any'){
    reqs.push({
      key:'university', label:'University: ' + (TUITION_LABELS.university[t.university]||t.university),
      test: function(r){ return (r.university||'').trim().toUpperCase() === String(t.university).toUpperCase(); }
    });
  }
  if(t.is_local === true){
    reqs.push({
      key:'local', label:'Chittagong Local Required',
      test: function(r){ return r.is_chittagong_local === true; }
    });
  }
  const classBuckets = classToBuckets(t.class);
  if(classBuckets){
    reqs.push({
      key:'class', label:'Class: ' + t.class,
      test: function(r){
        const arr = Array.isArray(r.preferred_class_levels) ? r.preferred_class_levels : [];
        return arr.some(function(b){ return classBuckets.has(b); });
      }
    });
  }
  if(t.group_type && t.group_type !== 'any'){
    reqs.push({
      key:'group', label:'Group: ' + (TUITION_LABELS.group_type[t.group_type]||t.group_type),
      test: function(r){
        const arr = Array.isArray(r.preferred_stream) ? r.preferred_stream : [];
        return arr.includes(t.group_type);
      }
    });
  }
  return reqs;
}

function matchReqPillsHTML(reqs){
  if(!reqs.length) return '<span class="match-req-pill">No mandatory filters — open to any tutor</span>';
  return reqs.map(function(r){ return '<span class="match-req-pill">' + escapeHtml(r.label) + '</span>'; }).join('');
}

const ONE_MONTH_MS = 30 * 24 * 60 * 60 * 1000;
function isOldRegistration(r){
  if(!r.created_at) return false;
  return (Date.now() - new Date(r.created_at).getTime()) > ONE_MONTH_MS;
}

// Ranks tutors by rating, but when two tutors' ratings are within 6 points of
// each other, prefers whoever registered more recently — keeps the list from
// getting stuck on old, similarly-scored profiles.
function compareTutorsForRanking(a, b){
  const ratingDiff = effectiveRating(b) - effectiveRating(a);
  if(Math.abs(ratingDiff) < 6){
    return new Date(b.created_at||0) - new Date(a.created_at||0);
  }
  return ratingDiff;
}

async function openMatchModal(id){
  const t = allTuitions.find(function(x){ return x.id === id; });
  if(!t) return;

  const matchOverlay = document.getElementById('matchOverlay');
  const matchTitle = document.getElementById('matchTitle');
  const matchSub = document.getElementById('matchSub');
  const matchReqs = document.getElementById('matchReqs');
  const matchBody = document.getElementById('matchBody');

  matchTitle.textContent = 'Son of Anton — ' + (t.code || '');
  matchSub.textContent = 'Finding the best-matched tutors for this tuition.';
  matchReqs.innerHTML = '';
  matchBody.innerHTML = '<div class="match-loading">Searching for Tutors...</div>';
  matchOverlay.classList.add('open');

  let applicants;
  try{
    const { data, error } = await sb.from('tm_applicants').select(APPLICANT_MATCH_COLUMNS);
    if(error) throw error;
    // Fully-banned tutors never appear in Son of Anton. Temporarily-SoA-banned
    // tutors are excluded only while their soa_ban_until is still in the future —
    // once it passes they're automatically eligible again, no action needed.
    const now = Date.now();
    applicants = (data || []).filter(function(r){
      if(!r.survey_completed) return false;
      if(r.is_banned) return false;
      if(r.soa_ban_until && new Date(r.soa_ban_until).getTime() > now) return false;
      return true;
    });
    await loadTutorAdjustments();
  }catch(err){
    matchBody.innerHTML = '<div class="match-notice fail">Failed to load tutors. ' + escapeHtml(err.message||'') + '</div>';
    console.error(err);
    return;
  }

  // Whoever's already been given this tuition's number is pinned to the top
  // of the modal no matter what — pulled out of the normal ranking pool so
  // they don't also show up further down.
  let pinnedTutor = null;
  if(t.assigned_tutor_whatsapp){
    pinnedTutor = applicants.find(function(r){ return r.whatsapp === t.assigned_tutor_whatsapp; })
      || { whatsapp: t.assigned_tutor_whatsapp, name: tutorNameByWhatsapp[t.assigned_tutor_whatsapp] || t.assigned_tutor_whatsapp };
    applicants = applicants.filter(function(r){ return r.whatsapp !== t.assigned_tutor_whatsapp; });
  }
  pinnedMatchTutor = pinnedTutor;
  const pinnedHtml = pinnedTutor
    ? '<div class="match-section-title">\uD83D\uDCCC Given the Number</div>' + pinnedCardHTML(pinnedTutor, t)
    : '';

  const reqs = buildMatchRequirements(t);
  matchReqs.innerHTML = matchReqPillsHTML(reqs);

  // Step A — mandatory qualification filter
  const poolA = applicants.filter(function(r){ return reqs.every(function(req){ return req.test(r); }); });

  if(poolA.length === 0){
    const blockers = reqs.filter(function(req){
      return applicants.filter(req.test).length === 0;
    }).map(function(req){ return req.label; });
    const reasonText = blockers.length
      ? blockers.join(', ')
      : (reqs.length ? 'no tutor satisfies all required qualifications together (' + reqs.map(function(r){return r.label;}).join(', ') + ')' : 'no survey-completed tutors available');
    matchBody.innerHTML = pinnedHtml + '<div class="match-notice fail">'
      + '\u274C No Tutor available for this — ' + escapeHtml(reasonText) + '.'
      + '</div>';
    wirePinnedDetailButton();
    return;
  }

  // Step B — salary floor check: tutor's absolute minimum (poor-student) charge
  // must be at or below the salary actually being offered.
  const salary = Number(t.salary) || 0;
  const poolB = poolA.filter(function(r){
    const floor = Number(r.poor_student_min_charge);
    return !isNaN(floor) && floor <= salary;
  });

  if(poolB.length === 0){
    const closest = poolA.slice().sort(function(a,b){
      const da = Math.abs((Number(a.poor_student_min_charge)||0) - salary);
      const db = Math.abs((Number(b.poor_student_min_charge)||0) - salary);
      return da - db;
    }).slice(0, 5);
    lastMatchPool = closest;
    matchBody.innerHTML = pinnedHtml +
      '<div class="match-notice warn">\u26A0\uFE0F No Tutor available for this — salary expectation is high. Showing the 5 closest by minimum salary.</div>'
      + '<div class="match-list">' + closest.map(function(r,i){ return matchCardHTML(r, i+1, salary, i, false, t); }).join('') + '</div>';
    wireMatchDetailButtons();
    wireGiveNumberButtons();
    wireRequestAccessButtons();
    wireGrantAccessButtons();
    wirePinnedDetailButton();
    return;
  }

  // Step C — zone team-up check: tutor's teamed-up zones must cover the
  // tuition's precise zone.
  const tuitionZoneNum = zoneNumberFromTuitionZone(t.zone);
  const poolC = tuitionZoneNum == null
    ? poolB
    : poolB.filter(function(r){ return tutorTeamZoneNumbers(r).has(tuitionZoneNum); });

  if(poolC.length === 0){
    matchBody.innerHTML = pinnedHtml + '<div class="match-notice fail">'
      + '\u274C No Tutor available for this — no tutor\'s teamed-up zone covers ' + escapeHtml(t.zone || 'this zone') + '.'
      + '</div>';
    wirePinnedDetailButton();
    return;
  }

  // Step D — everything qualifies. Rank by rating (ties within 6 points favor
  // the more recently registered tutor) and show the top 10.
  const ranked = poolC.slice().sort(compareTutorsForRanking);
  const top10 = ranked.slice(0, 10);

  // If an "old" (registered more than 1 month ago) tutor made the top 10,
  // also surface up to 10 more freshly registered tutors (< 1 month old) so
  // newer profiles still get visibility.
  let extraFresh = [];
  if(top10.some(isOldRegistration)){
    const top10Set = new Set(top10);
    extraFresh = ranked.filter(function(r){ return !top10Set.has(r) && !isOldRegistration(r); }).slice(0, 10);
  }

  lastMatchPool = top10.concat(extraFresh);

  const top10Html = top10.map(function(r,i){ return matchCardHTML(r, i+1, salary, i, isOldRegistration(r), t); }).join('');
  const extraHtml = extraFresh.length
    ? '<div class="match-section-title">10 more newly registered tutors (less than 1 month old)</div>'
      + extraFresh.map(function(r,i){ return matchCardHTML(r, top10.length+i+1, salary, top10.length+i, false, t); }).join('')
    : '';

  matchBody.innerHTML = pinnedHtml +
    '<div class="match-notice ok">\u2705 ' + top10.length + ' Tutor' + (top10.length===1?'':'s') + ' matched — sorted by rank.</div>'
    + '<div class="match-list">' + top10Html + extraHtml + '</div>';
  wireMatchDetailButtons();
  wireGiveNumberButtons();
  wireRequestAccessButtons();
  wireGrantAccessButtons();
  wirePinnedDetailButton();
}

