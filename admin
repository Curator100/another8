document.getElementById('colSaveBtn').addEventListener('click', async function(){
  const errEl = document.getElementById('collectionErr');
  errEl.textContent = '';
  const tuitionId = document.getElementById('colTuitionSelect').value || null;
  const payer = document.getElementById('colPayerName').value.trim();
  const paid = Number(document.getElementById('colAmountPaid').value);
  const remaining = Number(document.getElementById('colAmountRemaining').value || 0);
  const date = document.getElementById('colDate').value;
  const note = document.getElementById('colNote').value.trim();
  if(isNaN(paid) || paid < 0){ errEl.textContent = 'Enter a valid amount paid.'; return; }
  if(!date){ errEl.textContent = 'Pick the collection date.'; return; }
  const btn = document.getElementById('colSaveBtn');
  btn.disabled = true;
  try{
    const { error } = await sb.rpc('officer_add_collection', {
      p_admin_username: currentAdmin.username, p_admin_password_hash: currentAdmin.password_hash,
      p_tuition_id: tuitionId ? Number(tuitionId) : null, p_payer_name: payer || null,
      p_amount_paid: paid, p_amount_remaining: isNaN(remaining)?0:remaining,
      p_collected_date: date, p_note: note || null
    });
    if(error) throw error;
    document.getElementById('colPayerName').value = '';
    document.getElementById('colAmountPaid').value = '';
    document.getElementById('colAmountRemaining').value = '0';
    document.getElementById('colNote').value = '';
