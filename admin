/* =====================================================================
   MODMINS — admin/moderator account management (admin-role only)
   All calls re-send the logged-in admin's own username + password_hash so
   the backend (SECURITY DEFINER RPCs) can re-verify the caller is really
   an active admin before touching the tm_admins table. Nothing here can
   read tm_admins directly — RLS blocks that; these RPCs are the only door.
   ===================================================================== */

let allModmins = [];

async function loadModmins(){
  if(!currentAdmin) return;
  const errEl = document.getElementById('modminsErr');
  const table = document.getElementById('modminsTable');
  const loadingEl = document.getElementById('mLoadingState');
  const emptyEl = document.getElementById('mEmptyState');
  errEl.textContent = '';
  table.hidden = true;
  emptyEl.style.display = 'none';
  loadingEl.style.display = 'block';
  try{
    const { data, error } = await sb.rpc('admin_list_moderators', {
      p_admin_username: currentAdmin.username,
      p_admin_password_hash: currentAdmin.password_hash
    });
    if(error) throw error;
    allModmins = data || [];
    renderModmins();
  }catch(err){
    console.error(err);
    errEl.textContent = 'Failed to load accounts. ' + (err.message || '');
  }finally{
    loadingEl.style.display = 'none';
  }
}

function renderModmins(){
  const table = document.getElementById('modminsTable');
  const body = document.getElementById('modminsBody');
  const emptyEl = document.getElementById('mEmptyState');

  document.getElementById('mStatTotal').textContent = allModmins.length;
  document.getElementById('mStatActive').textContent = allModmins.filter(m => m.status === 'active').length;
  document.getElementById('mStatBanned').textContent = allModmins.filter(m => m.status === 'banned').length;

  if(!allModmins.length){
    table.hidden = true;
    emptyEl.style.display = 'block';
    return;
  }
  emptyEl.style.display = 'none';
  table.hidden = false;

  body.innerHTML = allModmins.map(function(m){
    const isSelf = m.username === currentAdmin.username;
    const created = m.created_at ? new Date(m.created_at).toLocaleDateString('en-GB') : '—';
    const statusBadge = m.status === 'banned'
      ? '<span style="color:#B5473B;font-weight:600;">Banned</span>'
      : '<span style="color:var(--teal-deep);font-weight:600;">Active</span>';
    const actionBtn = isSelf
      ? '<span style="color:var(--ink-soft);font-size:13px;">(you)</span>'
      : (m.status === 'banned'
        ? '<button type="button" class="icon-btn" data-unban="' + escapeHtml(m.username) + '">Unban</button>'
        : '<button type="button" class="icon-btn danger" data-ban="' + escapeHtml(m.username) + '">Ban</button>');
    return '<tr>'
      + '<td>' + escapeHtml(m.username) + '</td>'
      + '<td>' + escapeHtml(ROLE_LABELS[m.role] || m.role) + '</td>'
      + '<td>' + statusBadge + '</td>'
      + '<td>' + created + '</td>'
      + '<td>' + actionBtn + '</td>'
      + '</tr>';
  }).join('');

  body.querySelectorAll('[data-ban]').forEach(function(btn){
    btn.addEventListener('click', function(){ setModminStatus(btn.dataset.ban, 'banned'); });
  });
  body.querySelectorAll('[data-unban]').forEach(function(btn){
    btn.addEventListener('click', function(){ setModminStatus(btn.dataset.unban, 'active'); });
  });
}

async function setModminStatus(targetUsername, newStatus){
  const errEl = document.getElementById('modminsErr');
  errEl.textContent = '';
  try{
    const { error } = await sb.rpc('admin_set_moderator_status', {
      p_admin_username: currentAdmin.username,
      p_admin_password_hash: currentAdmin.password_hash,
      p_target_username: targetUsername,
      p_new_status: newStatus
    });
    if(error) throw error;
    await loadModmins();
  }catch(err){
    console.error(err);
    errEl.textContent = 'Action failed. ' + (err.message || '');
  }
}

