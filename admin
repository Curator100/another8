// Builds the guardian-number action for a matched tutor card, based on the
// logged-in officer's role:
//  - admin / moderator: original direct "Give Number" behaviour.
//  - relation_officer: can "Ask for Access" (never sees the number himself).
//  - privacy_officer: sees "Give Access" only once a Relation Officer has asked;
//    fulfilling it shares the number with the tutor without the PO seeing it.
//  - tuition_officer: never reaches here (Son of Anton is hidden for this role).
function buildAccessActionHTML(r, tuition, appliedForThis){
  if(!tuition || !currentAdmin) return '';
  const role = currentAdmin.role;
  const alreadyAssignedToThis = tuition.assigned_tutor_whatsapp === r.whatsapp;
  const alreadyAssignedToOther = tuition.assigned_tutor_whatsapp && tuition.assigned_tutor_whatsapp !== r.whatsapp;
  const pendingForThis = tuition.access_requested_tutor_whatsapp === r.whatsapp;

  if(role === 'admin' || role === 'moderator'){
    if(!appliedForThis) return '';
    if(alreadyAssignedToThis) return '<span class="match-req-pill" style="background:#E4F0E8;color:var(--teal-deep);border-color:#BFDFC9;">Number Given \u2705</span>';
    if(alreadyAssignedToOther && role === 'moderator'){
      return '<button type="button" class="icon-btn" disabled title="Already shared with another tutor — ask an admin to reassign.">Give Number</button>';
    }
    return '<button type="button" class="icon-btn soa" data-give-number="' + tuition.id + '" data-give-whatsapp="' + escapeHtml(r.whatsapp||'') + '">Give Number</button>';
  }

  if(role === 'relation_officer'){
    if(!appliedForThis) return '';
    if(alreadyAssignedToThis) return '<span class="match-req-pill" style="background:#E4F0E8;color:var(--teal-deep);border-color:#BFDFC9;">Access Given \u2705</span>';
    if(pendingForThis) return '<span class="match-req-pill" style="background:#FBF1D9;color:#8A6A16;border-color:#EFDBA0;">Requested \u23F3</span>';
    if(alreadyAssignedToOther) return '<button type="button" class="icon-btn" disabled title="Already shared with another tutor.">Ask for Access</button>';
    return '<button type="button" class="icon-btn soa" data-request-access="' + tuition.id + '" data-request-whatsapp="' + escapeHtml(r.whatsapp||'') + '">Ask for Access</button>';
  }

  if(role === 'privacy_officer'){
    if(alreadyAssignedToThis) return '<span class="match-req-pill" style="background:#E4F0E8;color:var(--teal-deep);border-color:#BFDFC9;">Access Given \u2705</span>';
    if(pendingForThis) return '<button type="button" class="icon-btn soa" data-grant-access="' + tuition.id + '">Give Access</button>';
    return '';
  }

  return '';
}

function matchCardHTML(r, rank, salary, idx, isOld, tuition){
  const floor = r.poor_student_min_charge != null ? '৳' + r.poor_student_min_charge : '—';
  const minExp = r.min_salary_expected != null ? '৳' + r.min_salary_expected : '—';
  const classes = lblList('preferred_class_levels', r.preferred_class_levels) || '—';
  const streams = lblList('preferred_stream', r.preferred_stream);
  const regDate = r.created_at ? new Date(r.created_at).toLocaleDateString('en-GB') : '—';
  const oldBadge = isOld
    ? '<div class="mc-meta old-badge">\u23F3 Old Registered Guy — registered ' + escapeHtml(regDate) + '</div>'
    : '';

  const appliedForThis = tuition && r.applied_tuition_code === tuition.code;
  const appliedBadge = appliedForThis
    ? '<span class="match-req-pill" style="background:#E4F0E8;color:var(--teal-deep);border-color:#BFDFC9;">Applied \u2705</span>'
    : '<span class="match-req-pill">Not Applied</span>';

  const giveNumberBtn = buildAccessActionHTML(r, tuition, appliedForThis);

  return '<div class="match-card">'
    + '<div class="mc-rank">#' + rank + '</div>'
    + '<div class="mc-name">' + escapeHtml(r.name||'') + ' <span style="font-weight:400;color:var(--ink-soft);">(' + escapeHtml(r.whatsapp||'') + ')</span></div>'
    + '<div class="mc-score">Rating: ' + effectiveRating(r) + '</div>'
    + '<div class="mc-meta">' + escapeHtml((TUITION_LABELS.university[String(r.university||'').toLowerCase()]) || r.university || '') + ' \u00B7 ' + escapeHtml(TUITION_LABELS.gender[r.gender]||r.gender||'') + ' \u00B7 ' + escapeHtml(TUITION_LABELS.religion[r.religion]||r.religion||'') + '</div>'
    + '<div class="mc-meta">Classes: ' + escapeHtml(classes) + (streams ? (' \u00B7 Stream: ' + escapeHtml(streams)) : '') + '</div>'
    + '<div class="mc-meta">Min. expected: ' + minExp + ' \u00B7 Poor-student floor: ' + floor + ' (tuition salary: \u09F3' + salary + ')</div>'
    + oldBadge
    + '<div class="mc-meta">' + appliedBadge + '</div>'
    + '<div class="mc-meta"><button type="button" class="icon-btn" data-match-detail="' + idx + '">Show Details</button> ' + giveNumberBtn + '</div>'
    + '</div>';
