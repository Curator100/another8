<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tuition O Job Media — Admin</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;500;600;700&family=Baloo+Da+2:wght@600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<style>
  :root{
    --bg:#FBF7EF; --surface:#FFFFFF; --ink:#2A2420; --ink-soft:#6B6155;
    --teal:#2F6F62; --teal-deep:#1C4A3E; --gold:#CB8A2E; --gold-soft:#F4E6C4;
    --terracotta:#C2643E;
    --line:#EAE2D0; --radius:16px; --shadow:0 10px 32px rgba(42,36,32,0.08);
    --shadow-soft:0 3px 14px rgba(42,36,32,0.05);
  }
  *{box-sizing:border-box;}
  body{margin:0;background:var(--bg);color:var(--ink);font-family:'Hind Siliguri',sans-serif;}
  h1,h2,.display{font-family:'Baloo Da 2',sans-serif;color:var(--teal-deep);margin:0;}
  button,input,select{font-family:inherit;}
  :focus-visible{outline:3px solid var(--gold);outline-offset:2px;}

  /* login */
  #loginScreen{
    min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;
    background:
      radial-gradient(circle at 15% 20%, rgba(47,111,98,0.09), transparent 46%),
      radial-gradient(circle at 85% 80%, rgba(203,138,46,0.12), transparent 46%),
      var(--bg);
  }
  .login-mark{
    display:flex;align-items:center;justify-content:center;
    width:52px;height:52px;border-radius:14px;margin:0 auto 16px;
    background:linear-gradient(135deg,var(--teal),var(--teal-deep));
    color:#fff;font-size:22px;font-family:'Baloo Da 2',sans-serif;font-weight:700;
    box-shadow:0 8px 20px rgba(28,74,62,0.24);
  }
  .login-card{
    background:var(--surface);padding:36px 30px 32px;border-radius:20px;box-shadow:var(--shadow);
    width:100%;max-width:360px;border:1px solid var(--line);text-align:center;
  }
  .login-card h1{font-size:23px;margin-bottom:4px;}
  .login-card p{color:var(--ink-soft);margin:0 0 24px;font-size:14px;}
  .login-card input{
    width:100%;padding:13px 15px;border-radius:11px;border:1.5px solid var(--line);
    background:var(--bg);font-size:15.5px;margin-bottom:12px;text-align:left;
    transition:border-color .2s ease, box-shadow .2s ease;
  }
  .login-card input:focus{
    outline:none;border-color:var(--teal);
    box-shadow:0 0 0 4px rgba(47,111,98,0.10);
  }
  .login-card button{
    width:100%;padding:13px;border:none;border-radius:11px;
    background:linear-gradient(135deg,var(--teal),var(--teal-deep));
    color:#fff;font-weight:600;font-size:15.5px;margin-top:6px;
    box-shadow:0 6px 16px rgba(28,74,62,0.18);
    transition:transform .15s ease, box-shadow .2s ease;
  }
  .login-card button:hover{transform:translateY(-1px);box-shadow:0 8px 20px rgba(28,74,62,0.26);}
  .login-err{color:#B5473B;font-size:13.5px;min-height:16px;margin-top:4px;}

  /* dashboard */
  #dashboard{display:none;padding:26px 20px 60px;max-width:1400px;margin:0 auto;}
  .dash-head{
    display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;
    margin-bottom:22px;
  }
  .dash-head h1{font-size:26px;}
  .dash-head .sub{color:var(--ink-soft);font-size:13.5px;margin-top:2px;}
  .logout-btn{
    background:none;border:1.5px solid var(--line);padding:9px 18px;border-radius:999px;
    color:var(--ink-soft);font-size:14px;font-weight:600;
    transition:.2s;
  }
  .logout-btn:hover{border-color:var(--terracotta);color:var(--terracotta);}
  .stats{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:22px;}
  .stat{
    background:var(--surface);border:1px solid var(--line);border-radius:14px;
    padding:16px 20px;box-shadow:var(--shadow);min-width:140px;
  }
  .stat .num{font-family:'Baloo Da 2';font-size:26px;color:var(--teal-deep);}
  .stat .label{font-size:13px;color:var(--ink-soft);}
  .toolbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;}
  .toolbar input{
    flex:1;min-width:180px;padding:10px 14px;border-radius:10px;border:1.5px solid var(--line);
    background:var(--surface);font-size:14.5px;
  }
  .toolbar select{
    padding:10px 14px;border-radius:10px;border:1.5px solid var(--line);
    background:var(--surface);font-size:14px;color:var(--ink);
  }
  .toolbar button{
    padding:10px 18px;border-radius:10px;border:1.5px solid var(--line);
    background:var(--surface);font-size:14px;font-weight:600;color:var(--ink);
  }
  .table-wrap{
    background:var(--surface);border-radius:14px;box-shadow:var(--shadow);
    overflow-x:auto;border:1px solid var(--line);
  }
  table{width:100%;border-collapse:collapse;font-size:13.5px;min-width:1500px;}
  th,td{padding:11px 13px;text-align:left;border-bottom:1px solid var(--line);white-space:nowrap;}
  th{
    background:var(--bg);color:var(--ink-soft);font-weight:600;font-size:12px;
    text-transform:uppercase;letter-spacing:.04em;position:sticky;top:0;
  }
  tr:hover td{background:var(--gold-soft);}
  .pill{
    display:inline-block;padding:2px 10px;border-radius:999px;font-size:12px;font-weight:600;
    background:var(--bg);color:var(--teal-deep);border:1px solid var(--line);
  }
  .pill.yes{background:#E4F0E8;color:var(--teal-deep);border-color:#BFDFC9;}
  .pill.no{background:#F5E7E4;color:#B5473B;border-color:#EAC9C2;}
  .pill.done{background:var(--teal);color:#fff;border-color:var(--teal);}
  .pill.pending{background:var(--bg);color:var(--ink-soft);}
  .detail-btn{
    padding:6px 14px;border-radius:8px;border:1.5px solid var(--line);background:var(--surface);
    font-size:12.5px;font-weight:600;color:var(--teal-deep);
  }
  .empty-state{padding:40px 20px;text-align:center;color:var(--ink-soft);}
  .loading-state{padding:40px 20px;text-align:center;color:var(--ink-soft);}

  /* detail drawer */
  .drawer-overlay{
    position:fixed;inset:0;background:rgba(32,40,37,0.5);display:none;
    align-items:center;justify-content:center;z-index:260;padding:16px;
  }
  .drawer-overlay.open{display:flex;}
  .drawer{
    background:var(--surface);border-radius:16px;max-width:640px;width:100%;
    max-height:88vh;overflow-y:auto;padding:24px 24px 30px;box-shadow:var(--shadow);
  }
  .drawer-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;}
  .drawer-top h2{font-size:20px;}
  .drawer-close{background:none;border:none;font-size:22px;color:var(--ink-soft);line-height:1;padding:4px;}
  .detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
  @media(max-width:520px){.detail-grid{grid-template-columns:1fr;}}
  .detail-item{
    background:var(--bg);border:1px solid var(--line);border-radius:10px;padding:10px 12px;
  }
  .detail-item .dl{font-size:11.5px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.04em;margin-bottom:3px;}
  .detail-item .dv{font-size:14.5px;font-weight:600;color:var(--ink);white-space:pre-wrap;}
  .detail-item.wide{grid-column:1/-1;}
  .detail-section-title{
    grid-column:1/-1;font-size:12.5px;font-weight:700;color:var(--teal);
    text-transform:uppercase;letter-spacing:.05em;margin-top:10px;margin-bottom:-2px;
  }

  /* tutor note banner + rank adjust (drawer) */
  .tutor-note-banner{
    grid-column:1/-1;background:#FBF1D9;border:1.5px solid #EFDBA0;border-radius:10px;
    padding:10px 14px;font-size:13.5px;color:#5C4816;white-space:pre-wrap;
  }
  .tutor-note-banner .tnb-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:#8A6A16;margin-bottom:3px;}
  .tutor-note-banner .tnb-meta{font-size:11px;color:#8A6A16;margin-top:6px;}
  .rank-adjust-box{
    grid-column:1/-1;background:var(--bg);border:1px solid var(--line);border-radius:10px;
    padding:12px 14px;display:flex;flex-direction:column;gap:10px;
  }
  .rank-adjust-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
  .rank-adjust-row .ra-btn{
    width:32px;height:32px;border-radius:8px;border:1.5px solid var(--line);background:var(--surface);
    font-size:16px;font-weight:700;color:var(--teal-deep);
  }
  .rank-adjust-row .ra-val{font-size:16px;font-weight:700;min-width:34px;text-align:center;}
  .rank-adjust-row .ra-base{font-size:12.5px;color:var(--ink-soft);}
  .rank-adjust-box textarea{
    width:100%;padding:9px 11px;border-radius:9px;border:1.5px solid var(--line);background:var(--surface);
    font-size:13.5px;font-family:inherit;resize:vertical;min-height:52px;
  }
  .rank-adjust-box .ra-save{
    align-self:flex-start;padding:8px 16px;border-radius:8px;border:none;
    background:var(--teal);color:#fff;font-size:13px;font-weight:600;
  }
  .guardian-history-list{grid-column:1/-1;display:flex;flex-direction:column;gap:6px;}
  .guardian-history-item{
    display:flex;justify-content:space-between;gap:10px;font-size:13px;
    background:var(--bg);border:1px solid var(--line);border-radius:8px;padding:8px 11px;
  }
  .guardian-history-item.revoked{opacity:.6;}

  /* tabs */
  .tabs{display:flex;gap:8px;margin-bottom:20px;}
  .tab-btn{
    padding:9px 20px;border-radius:999px;border:1.5px solid var(--line);background:var(--surface);
    font-size:14px;font-weight:600;color:var(--ink-soft);
  }
  .tab-btn.active{background:var(--teal);border-color:var(--teal);color:#fff;}

  /* tuitions */
  .post-btn{
    padding:10px 20px;border-radius:10px;border:none;background:var(--gold);
    color:var(--teal-deep);font-size:14px;font-weight:700;
  }
  .pill.open{background:#E4F0E8;color:var(--teal-deep);border-color:#BFDFC9;}
  .pill.filled{background:var(--bg);color:var(--ink-soft);}
  .pill.cancelled{background:#F5E7E4;color:#B5473B;border-color:#EAC9C2;}
  .pill.finished{background:#E0EAF5;color:#2A5C8A;border-color:#C4D9EE;}
  .pill.due{background:#FBF1D9;color:#8A6A16;border-color:#EFDBA0;}
  .row-actions{display:flex;gap:6px;}
  .icon-btn{
    padding:6px 12px;border-radius:8px;border:1.5px solid var(--line);background:var(--surface);
    font-size:12.5px;font-weight:600;color:var(--ink);
  }
  .icon-btn.danger{color:#B5473B;border-color:#EAC9C2;}
  .icon-btn.soa{background:var(--teal-deep);color:#fff;border-color:var(--teal-deep);}

  /* tuition form modal */
  .form-overlay{
    position:fixed;inset:0;background:rgba(32,40,37,0.5);display:none;
    align-items:center;justify-content:center;z-index:210;padding:16px;
  }
  .form-overlay.open{display:flex;}
  .form-modal{
    background:var(--surface);border-radius:16px;max-width:640px;width:100%;
    max-height:90vh;overflow-y:auto;padding:24px 24px 28px;box-shadow:var(--shadow);
  }
  .form-modal h2{font-size:20px;margin-bottom:4px;}
  .form-modal .sub{color:var(--ink-soft);font-size:13px;margin-bottom:18px;}
  .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  @media(max-width:520px){.form-grid{grid-template-columns:1fr;}}
  .form-field{display:flex;flex-direction:column;gap:5px;}
  .form-field.full{grid-column:1/-1;}
  .form-field label{font-size:12.5px;font-weight:600;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.03em;}
  .form-field input,.form-field select,.form-field textarea{
    padding:10px 12px;border-radius:9px;border:1.5px solid var(--line);background:var(--bg);
    font-size:14.5px;color:var(--ink);font-family:inherit;
  }
  .form-field textarea{resize:vertical;min-height:56px;}
  .form-field .hint{font-size:11.5px;color:var(--ink-soft);}
  .form-actions{display:flex;gap:10px;margin-top:20px;}
  .form-actions button{
    flex:1;padding:12px;border-radius:10px;font-size:15px;font-weight:600;border:1.5px solid var(--line);
  }
  .form-save{background:var(--teal);color:#fff;border-color:var(--teal);}
  .form-cancel{background:var(--surface);color:var(--ink-soft);}
  .form-err{color:#B5473B;font-size:13.5px;margin-top:10px;min-height:16px;}
  .section-note{
    grid-column:1/-1;font-size:12px;font-weight:700;color:var(--gold);
    text-transform:uppercase;letter-spacing:.05em;margin-top:6px;margin-bottom:-4px;
  }

  /* Son of Anton match modal */
  .match-overlay{
    position:fixed;inset:0;background:rgba(32,40,37,0.5);display:none;
    align-items:center;justify-content:center;z-index:220;padding:16px;
  }
  .match-overlay.open{display:flex;}
  .match-modal{
    background:var(--surface);border-radius:16px;max-width:820px;width:100%;
    max-height:90vh;overflow-y:auto;padding:24px 24px 28px;box-shadow:var(--shadow);
  }
  .match-modal h2{font-size:20px;margin-bottom:4px;}
  .match-sub{color:var(--ink-soft);font-size:13px;margin-bottom:16px;}
  .match-reqs{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px;}
  .match-req-pill{
    padding:5px 11px;border-radius:999px;font-size:12px;font-weight:600;
    border:1.5px solid var(--line);background:var(--bg);color:var(--ink-soft);
  }
  .match-notice{
    padding:14px 16px;border-radius:10px;font-size:14px;font-weight:600;margin-bottom:16px;
  }
  .match-notice.fail{background:#F5E7E4;color:#B5473B;border:1.5px solid #EAC9C2;}
  .match-notice.warn{background:#FBF1D9;color:#8A6A16;border:1.5px solid #EFDBA0;}
  .match-notice.ok{background:#E4F0E8;color:var(--teal-deep);border:1.5px solid #BFDFC9;}
  .match-list{display:flex;flex-direction:column;gap:10px;}
  .match-card{
    border:1.5px solid var(--line);border-radius:12px;padding:12px 14px;
    display:grid;grid-template-columns:auto 1fr auto;gap:4px 16px;align-items:center;
  }
  .match-card .mc-rank{
    font-size:18px;font-weight:800;color:var(--teal-deep);grid-row:1/3;
    width:34px;text-align:center;
  }
  .match-card .mc-name{font-size:15px;font-weight:700;color:var(--ink);}
  .match-card .mc-score{font-size:12.5px;font-weight:700;color:var(--gold);grid-row:1/3;white-space:nowrap;}
  .match-card .mc-meta{font-size:12.5px;color:var(--ink-soft);grid-column:2;}
  .match-close{
    margin-top:20px;width:100%;padding:12px;border-radius:10px;font-size:15px;font-weight:600;
    border:1.5px solid var(--line);background:var(--surface);color:var(--ink-soft);
  }
  .match-loading{padding:30px;text-align:center;color:var(--ink-soft);}
  .match-section-title{
    font-size:12.5px;font-weight:700;color:var(--teal);text-transform:uppercase;
    letter-spacing:.05em;margin:14px 2px 4px;
  }
  .old-badge{color:#8A6A16;font-weight:700;grid-column:2;}

  /* ---- ban controls (tutor drawer) ---- */
  .ban-box{grid-column:1/-1;border:1.5px solid var(--line);border-radius:12px;padding:14px;margin-bottom:4px;background:var(--bg);}
  .ban-status-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:10px;}
  .ban-status-row .pill.banned{background:#F5E7E4;color:#B5473B;border-color:#EAC9C2;}
  .ban-status-row .pill.soa-banned{background:#FBF1D9;color:#8A6A16;border-color:#EFDBA0;}
  .ban-status-row .pill.clear{background:#E4F0E8;color:var(--teal-deep);border-color:#BFDFC9;}
  .ban-actions{display:flex;gap:8px;flex-wrap:wrap;}
  .ban-actions button{padding:8px 14px;border-radius:9px;border:1.5px solid var(--line);background:var(--surface);font-size:13px;font-weight:600;color:var(--ink);}
  .ban-actions button.danger{color:#B5473B;border-color:#EAC9C2;}
  .ban-actions button.warn{color:#8A6A16;border-color:#EFDBA0;}
  .ban-inline-form{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;align-items:center;}
  .ban-inline-form input,.ban-inline-form textarea{padding:8px 10px;border-radius:8px;border:1.5px solid var(--line);background:var(--surface);font-size:13.5px;font-family:inherit;}
  .ban-inline-form input[type=number]{width:80px;}
  .ban-inline-form textarea{flex:1;min-width:160px;min-height:38px;resize:vertical;}
  .ban-history-list{grid-column:1/-1;display:flex;flex-direction:column;gap:6px;margin-top:8px;}
  .ban-history-item{border:1px solid var(--line);border-radius:9px;padding:8px 10px;font-size:12.5px;background:var(--surface);}
  .pill.mini-ban{background:#F5E7E4;color:#B5473B;border-color:#EAC9C2;}

  /* ---- due modal ---- */
  .due-overlay{position:fixed;inset:0;background:rgba(32,40,37,0.5);display:none;align-items:center;justify-content:center;z-index:230;padding:16px;}
  .due-overlay.open{display:flex;}
  .due-modal{background:var(--surface);border-radius:16px;max-width:600px;width:100%;max-height:90vh;overflow-y:auto;padding:24px 24px 28px;box-shadow:var(--shadow);}
  .due-modal h2{font-size:20px;margin-bottom:4px;}
  .due-current{background:var(--bg);border:1.5px solid var(--line);border-radius:11px;padding:12px 14px;margin:14px 0;font-size:14px;}
  .due-current b{color:var(--terracotta);font-size:17px;}
  .due-form{display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;margin-bottom:16px;}
  .due-form .form-field{flex:1;min-width:120px;}
  .due-history-item{border:1px solid var(--line);border-radius:9px;padding:9px 12px;font-size:13px;margin-bottom:8px;display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;}
  .due-history-item .dh-amt{font-weight:700;color:var(--terracotta);}
  .due-history-item .dh-meta{color:var(--ink-soft);font-size:11.5px;}

  /* ---- finance / collections panel ---- */
  .finance-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;}
  @media(max-width:820px){.finance-grid{grid-template-columns:1fr;}}
  .finance-card{background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:16px;box-shadow:var(--shadow-soft);}
  .finance-card h3{font-size:15px;margin:0 0 12px;color:var(--teal-deep);font-family:'Baloo Da 2';}
  .finance-form{display:flex;flex-wrap:wrap;gap:8px;}
  .finance-form input,.finance-form select{padding:8px 10px;border-radius:8px;border:1.5px solid var(--line);background:var(--bg);font-size:13.5px;font-family:inherit;flex:1;min-width:110px;}
  .finance-form button{padding:9px 16px;border-radius:9px;border:none;background:var(--teal);color:#fff;font-weight:600;font-size:13.5px;}
  .finance-toggle{display:flex;gap:8px;margin-bottom:16px;}
  .finance-toggle button{padding:8px 16px;border-radius:999px;border:1.5px solid var(--line);background:var(--surface);font-size:13px;font-weight:600;color:var(--ink-soft);}
  .finance-toggle button.active{background:var(--teal-deep);color:#fff;border-color:var(--teal-deep);}
  .chart-wrap{background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:16px;box-shadow:var(--shadow-soft);margin-bottom:20px;}
  .chart-wrap canvas{max-height:280px;}
  .fin-summary-row{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:16px;}
  .fin-summary-row .stat{min-width:150px;}
</style>
</head>
<body>

<div id="loginScreen">
  <div class="login-card">
    <div class="login-mark">টি</div>
    <h1>Tuition O Job Media</h1>
    <p>Admin Panel</p>
    <input type="text" id="adminUser" placeholder="Username" autocomplete="username">
    <input type="password" id="adminPass" placeholder="Password" autocomplete="current-password">
    <button id="loginBtn">Log In</button>
    <div class="login-err" id="loginErr"></div>
  </div>
</div>

<div id="dashboard">
  <div class="dash-head">
    <div>
      <h1 id="dashTitle">Applicants</h1>
      <div class="sub" id="lastUpdated"></div>
    </div>
    <button class="logout-btn" id="logoutBtn">Log Out</button>
  </div>

  <div class="tabs">
    <button class="tab-btn active" id="tabApplicants">Applicants</button>
    <button class="tab-btn" id="tabTuitions">Tuitions</button>
    <button class="tab-btn" id="tabDues" style="display:none;">Dues</button>
    <button class="tab-btn" id="tabFinance" style="display:none;">Collections</button>
    <button class="tab-btn" id="tabModmins" style="display:none;">Modmins</button>
  </div>

