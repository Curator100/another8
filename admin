function wireRankAdjustBox(r){
  const role = currentAdmin ? currentAdmin.role : null;
  if(!canAdjustTutorRank(role)) return;
  const valEl = document.getElementById('raVal');
  const totalEl = document.getElementById('raTotal');
  const base = computeRating(r);
  if(!valEl) return;
  const step = function(delta){
    let v = Number(valEl.dataset.val) || 0;
    v = Math.max(-7, Math.min(7, v + delta));
    valEl.dataset.val = v;
    valEl.textContent = (v>0?'+':'') + v;
    if(totalEl) totalEl.textContent = base + v;
  };
  const minusBtn = document.getElementById('raMinus');
  const plusBtn = document.getElementById('raPlus');
  if(minusBtn) minusBtn.addEventListener('click', function(){ step(-1); });
  if(plusBtn) plusBtn.addEventListener('click', function(){ step(1); });

  const saveBtn = document.getElementById('raSave');
  if(saveBtn){
    saveBtn.addEventListener('click', async function(){
      const msgEl = document.getElementById('raSaveMsg');
      const noteVal = document.getElementById('raNote').value.trim();
      const rankVal = Number(valEl.dataset.val) || 0;
      saveBtn.disabled = true;
      msgEl.textContent = 'Saving...';
      try{
        const { error } = await sb.rpc('officer_update_tutor_adjustment', {
          p_admin_username: currentAdmin.username,
          p_admin_password_hash: currentAdmin.password_hash,
          p_tutor_whatsapp: r.whatsapp,
          p_rank_adjustment: rankVal,
          p_note: noteVal || null
        });
        if(error) throw error;
        tutorAdjustments[r.whatsapp] = {
          whatsapp: r.whatsapp, rank_adjustment: rankVal, note: noteVal || null,
          updated_by: currentAdmin.username, updated_at: new Date().toISOString()
        };
        msgEl.textContent = 'Saved.';
        document.getElementById('drawerNoteBanner').innerHTML = noteBannerHTML(tutorAdjustments[r.whatsapp]);
        applyFilters(); // refresh table rating column if visible
      }catch(err){
        console.error(err);
        msgEl.textContent = 'Failed to save. ' + (err.message || '');
      }finally{
        saveBtn.disabled = false;
      }
    });
  }
}

