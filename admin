// Whether the guardian number for tuition `t` is currently unlocked for the
// logged-in Tuition Officer — either revealed earlier this tab session, or
// already on record server-side as revealed by this same officer.
function officerHasRevealed(t){
  if(revealedGuardianNumbers[t.id] && revealedGuardianNumbers[t.id].number) return true;
  return !!(currentAdmin && t.guardian_seen_by === currentAdmin.username && t.guardian_number);
}
function officerRevealedNumber(t){
  const cached = revealedGuardianNumbers[t.id];
  if(cached && cached.number) return cached.number;
  if(currentAdmin && t.guardian_seen_by === currentAdmin.username) return t.guardian_number;
  return null;
}

async function revealGuardianNumber(tuitionId){
  if(!currentAdmin) return;
  try{
    const { data, error } = await sb.rpc('officer_reveal_guardian_number', {
      p_admin_username: currentAdmin.username,
      p_admin_password_hash: currentAdmin.password_hash,
      p_tuition_id: tuitionId
    });
    if(error) throw error;
    const seenAt = (data && data.guardian_seen_at) || new Date().toISOString();
    revealedGuardianNumbers[tuitionId] = {
      number: data && data.guardian_number,
      seenBy: currentAdmin.username,
      seenAt: seenAt
    };
    // Reflect the reveal on the in-memory row immediately too, so every place
    // that reads this tuition (table cell, the edit form) is consistent within
    // this session even before the next full loadTuitions() refresh.
    const row = allTuitions.find(function(x){ return x.id === tuitionId; });
