let allDues = [];
async function loadDues(){
  document.getElementById('dLoadingState').style.display = 'block';
  document.getElementById('duesTable').hidden = true;
  document.getElementById('dEmptyState').style.display = 'none';
  try{
    const { data, error } = await sb.rpc('admin_get_all_dues', {
      p_admin_username: currentAdmin.username, p_admin_password_hash: currentAdmin.password_hash
    });
    if(error) throw error;
    allDues = (data || []).filter(function(d){ return Number(d.amount_due) > 0; });
    applyDuesFilter();
  }catch(err){
    document.getElementById('dLoadingState').textContent = 'Failed to load dues.';
    console.error(err);
  }
}
function dueBucket(dateStr){
  const today = new Date(); today.setHours(0,0,0,0);
  const d = new Date(dateStr); d.setHours(0,0,0,0);
  if(d.getTime() < today.getTime()) return 'overdue';
  if(d.getTime() === today.getTime()) return 'today';
  return 'upcoming';
}
function applyDuesFilter(){
  const val = document.getElementById('dFilter').value;
  let rows = allDues;
  if(val) rows = rows.filter(function(d){ return dueBucket(d.due_date) === val; });
  renderDues(rows);
}
function renderDues(rows){
  document.getElementById('dLoadingState').style.display = 'none';
  document.getElementById('dStatTotal').textContent = allDues.length;
  document.getElementById('dStatOverdue').textContent = allDues.filter(function(d){ return dueBucket(d.due_date)==='overdue'; }).length;
  document.getElementById('dStatToday').textContent = allDues.filter(function(d){ return dueBucket(d.due_date)==='today'; }).length;
  document.getElementById('dStatUpcoming').textContent = allDues.filter(function(d){ return dueBucket(d.due_date)==='upcoming'; }).length;
  document.getElementById('dStatAmount').textContent = moneyFmt(allDues.reduce(function(s,d){ return s + Number(d.amount_due||0); }, 0));

  if(!rows.length){
    document.getElementById('dEmptyState').style.display = 'block';
    document.getElementById('duesTable').hidden = true;
    return;
  }
  document.getElementById('duesTable').hidden = false;
  const BUCKET_PILL = { overdue:'<span class="pill mini-ban">Overdue</span>', today:'<span class="pill" style="background:#FBF1D9;color:#8A6A16;border-color:#EFDBA0;">Today</span>', upcoming:'<span class="pill clear" style="background:#E4F0E8;color:var(--teal-deep);border-color:#BFDFC9;">Upcoming</span>' };
  document.getElementById('duesBody').innerHTML = rows.map(function(d){
    return '<tr>'
      + '<td><span class="pill">' + escapeHtml(d.code||'') + '</span></td>'
      + '<td>' + escapeHtml(d.location||'') + '</td>'
      + '<td>' + (d.salary!=null?moneyFmt(d.salary):'') + '</td>'
      + '<td><b>' + moneyFmt(d.amount_due) + '</b></td>'
      + '<td>' + new Date(d.due_date).toLocaleDateString('en-GB') + ' ' + BUCKET_PILL[dueBucket(d.due_date)] + '</td>'
      + '<td>' + escapeHtml(d.note||'') + '</td>'
      + '<td>' + escapeHtml(d.updated_by||'') + '</td>'
      + '<td>' + new Date(d.created_at).toLocaleString('en-GB') + '</td>'
      + '<td><button class="icon-btn" data-open-due="' + d.tuition_id + '">Update</button></td>'
      + '</tr>';
  }).join('');
  document.getElementById('duesBody').querySelectorAll('[data-open-due]').forEach(function(btn){
    btn.addEventListener('click', async function(){
      // Dues page may run before the Tuitions tab has ever loaded allTuitions —
      // make sure it's populated so openDueModal can find the row.
      if(!allTuitions.length) await loadTuitions();
      openDueModal(Number(btn.dataset.openDue));
    });
  });
}
