/* ---------- tutor banning (full ban + temporary Son-of-Anton-only ban) ---------- */

// 'full' = never shows in Son of Anton, and the public site only ever shows him
//          the randomly-generated placeholder tuitions from now on.
// 'soa'  = excluded from Son of Anton only, until soa_ban_until passes, then
//          automatically eligible again.
// 'clear' = neither.
function tutorBanStatus(r){
  if(r.is_banned) return 'full';
  if(r.soa_ban_until && new Date(r.soa_ban_until).getTime() > Date.now()) return 'soa';
  return 'clear';
}
function tutorBanBadgeMini(r){
  const s = tutorBanStatus(r);
  if(s === 'full') return ' <span class="pill mini-ban">Banned</span>';
  if(s === 'soa') return ' <span class="pill mini-ban" style="background:#FBF1D9;color:#8A6A16;border-color:#EFDBA0;">SoA Banned</span>';
  return '';
}

function banStatusRowHTML(r){
  const s = tutorBanStatus(r);
  if(s === 'full'){
    return '<div class="ban-status-row"><span class="pill banned">\uD83D\uDEAB Fully Banned</span>'
      + (r.ban_reason ? '<span style="font-size:12.5px;color:var(--ink-soft);">' + escapeHtml(r.ban_reason) + '</span>' : '')
      + '<span style="font-size:11.5px;color:var(--ink-soft);">by ' + escapeHtml(r.banned_by||'') + (r.banned_at ? ' \u00b7 ' + new Date(r.banned_at).toLocaleDateString('en-GB') : '') + '</span></div>';
  }
  if(s === 'soa'){
    return '<div class="ban-status-row"><span class="pill soa-banned">\u23F3 SoA-banned until ' + new Date(r.soa_ban_until).toLocaleDateString('en-GB') + '</span>'
      + (r.soa_ban_reason ? '<span style="font-size:12.5px;color:var(--ink-soft);">' + escapeHtml(r.soa_ban_reason) + '</span>' : '')
      + '</div>';
  }
  return '<div class="ban-status-row"><span class="pill clear">\u2705 No ban in effect</span></div>';
}

function banBoxHTML(r){
  const role = currentAdmin ? currentAdmin.role : null;
  if(!canBanTutor(role)) return '';
  const s = tutorBanStatus(r);
  let actions = '';
  if(s === 'full'){
    actions = '<button type="button" id="banUnbanFullBtn">Remove Full Ban</button>';
  } else {
    actions = '<button type="button" class="danger" id="banFullBtn">Full Ban</button>';
    if(s === 'soa'){
      actions += '<button type="button" class="warn" id="banSoaEndBtn">End SoA Ban Early</button>';
    } else {
      actions += '<button type="button" class="warn" id="banSoaBtn">Temporary SoA Ban</button>';
    }
  }
  return '<div class="ban-box">'
    + '<div class="detail-section-title" style="margin:0 0 8px;">Ban Controls</div>'
    + banStatusRowHTML(r)
    + '<div class="ban-actions">' + actions + '</div>'
    + '<div class="ban-inline-form" id="banFullForm" style="display:none;">'
      + '<input type="text" id="banFullReason" placeholder="Reason for full ban">'
      + '<button type="button" id="banFullConfirm">Confirm Ban</button>'
    + '</div>'
    + '<div class="ban-inline-form" id="banSoaForm" style="display:none;">'
      + '<input type="number" id="banSoaDays" placeholder="Days" min="1">'
      + '<input type="text" id="banSoaReason" placeholder="Reason (optional)">'
      + '<button type="button" id="banSoaConfirm">Confirm SoA Ban</button>'
    + '</div>'
    + '<div id="banSaveMsg" style="font-size:12px;color:var(--ink-soft);margin-top:6px;"></div>'
    + '<div id="banHistorySection" class="ban-history-list"></div>'
    + '</div>';
}

async function refreshDrawerBanBox(r){
  const box = document.getElementById('drawerBanBox');
  if(!box) return;
  box.innerHTML = banBoxHTML(r);
  wireBanBox(r);
  loadBanHistoryIntoDrawer(r.whatsapp);
