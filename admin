/* ---------- rating logic (points per survey answer, higher = better applicant) ---------- */
function computeRating(r){
  let score = 0;

  // university
  const uni = (r.university || '').trim().toUpperCase();
  if(uni === 'CMC' || uni === 'CUET') score += 8;
  else if(uni === 'CU') score += 5;
  else if(uni === 'CVASU') score += 3;
  else score += 2; // any other institute

  // year
  const y = r.year || '';
  if(y === '১ম বর্ষ') score += 5;
  else if(y === '৪র্থ বর্ষ') score += 3;
  else if(y === '২য় বর্ষ' || y === '৩য় বর্ষ' || y === 'মাস্টার্স' || y === 'পিএইচডি') score += 2;

  // gender
  if(r.gender === 'male') score += 5;
  else if(r.gender === 'female') score += 4;

  // current tuitions
  const ct = r.current_tuition_count;
  if(ct === '0') score += 5;
  else if(ct === '4' || ct === '5+') score += 4;
  else if(ct === '1' || ct === '2' || ct === '3') score += 3;

  // chittagong local
  if(r.is_chittagong_local === true) score += 5;
  else if(r.is_chittagong_local === false) score += 3;

  // transportation
  if(r.transportation_mode === 'own_vehicle') score += 5;
  else if(r.transportation_mode === 'uber_pathao' || r.transportation_mode === 'cng') score += 4;
  else if(r.transportation_mode === 'rickshaw') score += 3;
  else if(r.transportation_mode === 'local_bus') score += 2;

  // food delivery
  if(r.ordered_food_delivery_4months === true) score += 5;
  else if(r.ordered_food_delivery_4months === false) score += 3;

  // ssc gpa
  if(r.ssc_gpa !== null && r.ssc_gpa !== undefined && r.ssc_gpa !== ''){
    const gpa = Number(r.ssc_gpa);
    if(!isNaN(gpa)){
      if(gpa >= 5) score += 5;
      else if(gpa >= 4) score += 4;
      else if(gpa >= 3) score += 3;
      else score -= 5;
    }
  }

  // self studied with home tutor (ssc/hsc)
  if(r.self_studied_with_tutor_ssc_hsc === true) score += 5;
  else if(r.self_studied_with_tutor_ssc_hsc === false) score += 3;

  // monthly personal expense
  if(r.monthly_personal_expense !== null && r.monthly_personal_expense !== undefined && r.monthly_personal_expense !== ''){
    const exp = Number(r.monthly_personal_expense);
    if(!isNaN(exp)){
      if(exp >= 10000) score += 5;
      else if(exp >= 7000) score += 4;
      else if(exp >= 5000) score += 3;
      else score += 2;
    }
  }

  // personal earning goal (desired monthly earning)
  if(r.desired_monthly_earning !== null && r.desired_monthly_earning !== undefined && r.desired_monthly_earning !== ''){
    const goal = Number(r.desired_monthly_earning);
    if(!isNaN(goal)){
      if(goal >= 10000) score += 5;
      else if(goal >= 7000) score += 4;
      else if(goal >= 5000) score += 3;
      else score += 2;
    }
  }

  // income source
  const src = Array.isArray(r.current_income_source) ? r.current_income_source : [];
  if(src.includes('family_support')) score += 5;
  else if(src.length) score += 3;

  // core reason to earn money
  if(r.tuition_main_goal === 'family_support') score += 0;
  else if(r.tuition_main_goal) score += 5;

  // family supportive for tuitions
  if(r.family_supports_tuition === true) score += 5;
  else if(r.family_supports_tuition === false) score += 3;

  return score;
}

/* ---------- manual rank adjustment + note (Admin / Moderator / Relation Officer) ----------
   whatsapp -> { rank_adjustment, note, updated_by, updated_at }, loaded in bulk from
   tm_tutor_adjustments so both the Applicants table and Son of Anton ranking reflect
   the same manually-nudged rating everywhere. */
let tutorAdjustments = {};

async function loadTutorAdjustments(){
  try{
    const { data, error } = await sb.from('tm_tutor_adjustments').select('whatsapp,rank_adjustment,note,updated_by,updated_at');
    if(error) throw error;
    tutorAdjustments = {};
    (data || []).forEach(function(row){ tutorAdjustments[row.whatsapp] = row; });
  }catch(err){ console.error('Failed to load tutor adjustments', err); }
}

function rankAdjustmentFor(whatsapp){
  const a = tutorAdjustments[whatsapp];
  return a ? Number(a.rank_adjustment) || 0 : 0;
}

// Rating actually used everywhere for sorting/ranking/display — base survey
// score plus whatever manual nudge (-7..+7) an officer has applied.
function effectiveRating(r){
  return computeRating(r) + rankAdjustmentFor(r.whatsapp);
}

function canAdjustTutorRank(role){
  return role === 'admin' || role === 'moderator' || role === 'relation_officer';
}

