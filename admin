document.getElementById('modminFormCancel').addEventListener('click', function(){ modminFormOverlay.classList.remove('open'); });
modminFormOverlay.addEventListener('click', function(e){ if(e.target === modminFormOverlay) modminFormOverlay.classList.remove('open'); });

document.getElementById('modminFormSave').addEventListener('click', async function(){
  const username = document.getElementById('mf_username').value.trim();
  const password = document.getElementById('mf_password').value;
  const role = document.getElementById('mf_role').value;
  if(!username){ modminFormErr.textContent = 'Username is required.'; return; }
  if(!password || password.length < 6){ modminFormErr.textContent = 'Password must be at least 6 characters.'; return; }

  const saveBtn = document.getElementById('modminFormSave');
  saveBtn.disabled = true;
  try{
    const new_password_hash = await sha256Hex(password);
    const { error } = await sb.rpc('admin_create_moderator', {
      p_admin_username: currentAdmin.username,
      p_admin_password_hash: currentAdmin.password_hash,
      p_new_username: username,
      p_new_password_hash: new_password_hash,
      p_new_role: role
    });
    if(error) throw error;
    modminFormOverlay.classList.remove('open');
    await loadModmins();
  }catch(err){
    console.error(err);
    modminFormErr.textContent = 'Could not create account. ' + (err.message || 'That username may already be taken.');
  }finally{
    saveBtn.disabled = false;
  }
});
</script>

