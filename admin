// tuition id -> { number, seenBy, seenAt } once a Tuition Officer has clicked "See
// Guardian Number" this session. This is a client-side cache for the current tab
// only; the durable source of truth is tm_tuitions.guardian_seen_by / guardian_seen_at,
// written by the officer_reveal_guardian_number RPC and read back below via
// t.guardian_seen_by / t.guardian_seen_at (loaded fresh with the rest of the row from
// admin_get_tuitions) — that's what makes the reveal visible to Admin/Moderator too,
// and what makes it survive a page reload for the officer who revealed it.
let revealedGuardianNumbers = {};

function applyGuardianColumnVisibility(){
  const role = currentAdmin ? currentAdmin.role : null;
