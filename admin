async function tryLogin(){
  const u = document.getElementById('adminUser').value.trim();
  const p = document.getElementById('adminPass').value;
  const errEl = document.getElementById('loginErr');
  errEl.textContent = '';
  if(!u || !p) return;

  const loginBtn = document.getElementById('loginBtn');
  loginBtn.disabled = true;
  try{
    const password_hash = await sha256Hex(p);
    const { data, error } = await sb.rpc('verify_admin_login', { p_username: u, p_password_hash: password_hash });
    if(error) throw error;
    const row = Array.isArray(data) ? data[0] : data;
    if(!row){
      errEl.textContent = 'Incorrect username or password.';
      return;
    }
    if(row.status === 'banned'){
      errEl.textContent = 'This account has been banned.';
      return;
    }
    currentAdmin = { username: u, role: row.role, password_hash };
    localStorage.setItem('tm_admin_session', JSON.stringify(currentAdmin));
    showDashboard();
  }catch(err){
    console.error(err);
    errEl.textContent = 'Login failed — please try again.';
  }finally{
    loginBtn.disabled = false;
  }
}

